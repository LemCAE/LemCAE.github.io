Windows Registry Editor Version 5.00
[HKEY_CLASSES_ROOT\JsonEditor]
@="URL:JsonEditor Protocol Handler"
"URL Protocol"=""
[HKEY_CLASSES_ROOT\JsonEditor\DefaultIcon]
@="H:\\ReNamer\\ReNamer.exe\"
[HKEY_CLASSES_ROOT\JsonEditor\shell]
[HKEY_CLASSES_ROOT\JsonEditor\shell\open]
[HKEY_CLASSES_ROOT\JsonEditor\shell\open\command]
@="\"H:\\ReNamer\\ReNamer.exe\" \"%1\""